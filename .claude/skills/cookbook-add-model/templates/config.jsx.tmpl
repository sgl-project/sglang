    parsers: {
      items: [
        { id: "reasoning", label: "Reasoning Parser", flag: "--reasoning-parser __REASONING_PARSER__" },
        { id: "toolCall",  label: "Tool Call Parser", flag: "--tool-call-parser __TOOLCALL_PARSER__" },
      ],
