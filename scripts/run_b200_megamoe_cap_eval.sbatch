#!/bin/bash
#SBATCH -J mm-cap-eval
#SBATCH -p b200@500-1000W/umbriel-b200@ts4/8gpu-224cpu-2048gb
#SBATCH -N 1
#SBATCH --gres=gpu:2
#SBATCH -t 04:00:00
#SBATCH -o /home/scratch.xutingz_wwfo_2/megamoe_cap_eval_%j.out
#SBATCH -e /home/scratch.xutingz_wwfo_2/megamoe_cap_eval_%j.err

set -euo pipefail

echo "HOST=$(hostname)"
echo "JOB_ID=${SLURM_JOB_ID:-none}"
echo "CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-unset}"
nvidia-smi -L || true

REPO=${REPO:-/home/scratch.xutingz_wwfo_2/sglang-megamoe-waterfill-bench}
SCRATCH=/home/scratch.xutingz_wwfo_2
MODEL_DIR=${MODEL_DIR:-$SCRATCH/model/DeepSeek-V4-Flash}
MODEL_IN_CONTAINER=${MODEL_IN_CONTAINER:-}
if [ -z "$MODEL_IN_CONTAINER" ]; then
  case "$MODEL_DIR" in
    "$SCRATCH"/*) MODEL_IN_CONTAINER=/host_scratch${MODEL_DIR#"$SCRATCH"} ;;
    *) echo "MODEL_DIR must live under $SCRATCH or MODEL_IN_CONTAINER must be set"; exit 2 ;;
  esac
fi
RESULT_ROOT=$SCRATCH/megamoe_cap_eval_${SLURM_JOB_ID}
mkdir -p "$RESULT_ROOT"
DEFAULT_PORT=$((30000 + SLURM_JOB_ID % 10000))

if [ -f "$MODEL_DIR/.download_in_progress" ]; then
  echo "MODEL_DOWNLOAD_IN_PROGRESS $MODEL_DIR"
  exit 2
fi

if [ ! -f "$MODEL_DIR/.download_complete" ] && { [ ! -f "$MODEL_DIR/config.json" ] || ! find "$MODEL_DIR" -maxdepth 1 -name '*.safetensors' -print -quit | grep -q .; }; then
  echo "MODEL_NOT_READY $MODEL_DIR"
  exit 2
fi

DOCKER_GPU_ARG=all
DOCKER_ENV_GPU_ARGS=()
if [ -n "${CUDA_VISIBLE_DEVICES:-}" ]; then
  IFS=',' read -r -a CUDA_DEVICE_LIST <<<"${CUDA_VISIBLE_DEVICES}"
  CONTAINER_CUDA_VISIBLE_DEVICES=$(seq -s, 0 $((${#CUDA_DEVICE_LIST[@]} - 1)))
  DOCKER_ENV_GPU_ARGS=(-e CUDA_VISIBLE_DEVICES="${CONTAINER_CUDA_VISIBLE_DEVICES}")
fi
DOCKER_ENV_WATERFILL_ARGS=()
if [ -n "${SGLANG_WATERFILL_FUSE_MEGA_MOE_PREDISPATCH:-}" ]; then
  DOCKER_ENV_WATERFILL_ARGS+=(
    -e SGLANG_WATERFILL_FUSE_MEGA_MOE_PREDISPATCH="${SGLANG_WATERFILL_FUSE_MEGA_MOE_PREDISPATCH}"
  )
fi
if [ -n "${SGLANG_WATERFILL_SHARED_REPLICAS_PER_RANK:-}" ]; then
  DOCKER_ENV_WATERFILL_ARGS+=(
    -e SGLANG_WATERFILL_SHARED_REPLICAS_PER_RANK="${SGLANG_WATERFILL_SHARED_REPLICAS_PER_RANK}"
  )
fi
if [ -n "${SGLANG_WATERFILL_ONE_WAY_REMOTE_SHARED:-}" ]; then
  DOCKER_ENV_WATERFILL_ARGS+=(
    -e SGLANG_WATERFILL_ONE_WAY_REMOTE_SHARED="${SGLANG_WATERFILL_ONE_WAY_REMOTE_SHARED}"
  )
fi
echo "DOCKER_GPU_ARG=${DOCKER_GPU_ARG}"
echo "CONTAINER_CUDA_VISIBLE_DEVICES=${CONTAINER_CUDA_VISIBLE_DEVICES:-unset}"

docker run --rm --gpus "${DOCKER_GPU_ARG}" --ipc=host --shm-size=64g \
  --user "$(id -u):$(id -g)" \
  "${DOCKER_ENV_GPU_ARGS[@]}" \
  "${DOCKER_ENV_WATERFILL_ARGS[@]}" \
  -e SLURM_JOB_ID="${SLURM_JOB_ID}" \
  -e PORT="${PORT:-$DEFAULT_PORT}" \
  -e CASE_PORT_STRIDE="${CASE_PORT_STRIDE:-1000}" \
  -e MODEL="$MODEL_IN_CONTAINER" \
  -e MEGA_MOE_CAP="${MEGA_MOE_CAP:-8320}" \
  -e MEGA_MOE_CAP_BUCKETS="${MEGA_MOE_CAP_BUCKETS:-}" \
  -e MAX_PREFILL_TOKENS="${MAX_PREFILL_TOKENS:-8192}" \
  -e CHUNKED_PREFILL_SIZE="${CHUNKED_PREFILL_SIZE:-8192}" \
  -e KV_CACHE_DTYPE="${KV_CACHE_DTYPE:-fp8_e4m3}" \
  -e MOE_A2A_BACKEND="${MOE_A2A_BACKEND:-megamoe}" \
  -e MOE_RUNNER_BACKEND="${MOE_RUNNER_BACKEND:-}" \
  -e DEEPEP_CONFIG="${DEEPEP_CONFIG:-}" \
  -e EP_NUM_REDUNDANT_EXPERTS="${EP_NUM_REDUNDANT_EXPERTS:-0}" \
  -e EP_DISPATCH_ALGORITHM="${EP_DISPATCH_ALGORITHM:-}" \
  -e INIT_EXPERT_LOCATION="${INIT_EXPERT_LOCATION:-}" \
  -e ENABLE_EPLB="${ENABLE_EPLB:-0}" \
  -e EPLB_ALGORITHM="${EPLB_ALGORITHM:-}" \
  -e EPLB_REBALANCE_NUM_ITERATIONS="${EPLB_REBALANCE_NUM_ITERATIONS:-}" \
  -e EPLB_REBALANCE_LAYERS_PER_CHUNK="${EPLB_REBALANCE_LAYERS_PER_CHUNK:-}" \
  -e EPLB_MIN_REBALANCING_UTILIZATION_THRESHOLD="${EPLB_MIN_REBALANCING_UTILIZATION_THRESHOLD:-}" \
  -e EXPERT_DISTRIBUTION_RECORDER_MODE="${EXPERT_DISTRIBUTION_RECORDER_MODE:-}" \
  -e EXPERT_DISTRIBUTION_RECORDER_BUFFER_SIZE="${EXPERT_DISTRIBUTION_RECORDER_BUFFER_SIZE:-}" \
  -e EXTRA_SERVER_ARGS="${EXTRA_SERVER_ARGS:-}" \
  -e SGLANG_DEEPEP_NUM_MAX_DISPATCH_TOKENS_PER_RANK="${SGLANG_DEEPEP_NUM_MAX_DISPATCH_TOKENS_PER_RANK:-1024}" \
  -e SGLANG_DISABLE_STATIC_WATERFILL="${SGLANG_DISABLE_STATIC_WATERFILL:-0}" \
  -e SGLANG_WATERFILL_LOG_STATS_INTERVAL="${SGLANG_WATERFILL_LOG_STATS_INTERVAL:-0}" \
  -e SGLANG_WATERFILL_LOG_ALL_RANKS="${SGLANG_WATERFILL_LOG_ALL_RANKS:-0}" \
  -e SGLANG_WATERFILL_FORCE_LOCAL_SHARED="${SGLANG_WATERFILL_FORCE_LOCAL_SHARED:-0}" \
  -e SGLANG_WATERFILL_STATIC_ALLOW_ALL_RANKS="${SGLANG_WATERFILL_STATIC_ALLOW_ALL_RANKS:-1}" \
  -e SGLANG_WATERFILL_LOCAL_PREF_NUMER="${SGLANG_WATERFILL_LOCAL_PREF_NUMER:-11}" \
  -e SGLANG_WATERFILL_LOCAL_PREF_DENOM="${SGLANG_WATERFILL_LOCAL_PREF_DENOM:-10}" \
  -e SGLANG_WATERFILL_REMOTE_COST_TOKENS="${SGLANG_WATERFILL_REMOTE_COST_TOKENS:-0}" \
  -e SGLANG_WATERFILL_SOURCE_AWARE_STATIC_LOAD="${SGLANG_WATERFILL_SOURCE_AWARE_STATIC_LOAD:-0}" \
  -e SGLANG_WATERFILL_STATIC_BLOCK_LOAD_M="${SGLANG_WATERFILL_STATIC_BLOCK_LOAD_M:-0}" \
  -e SGLANG_WATERFILL_REUSE_TOPK_BUFFER="${SGLANG_WATERFILL_REUSE_TOPK_BUFFER:-0}" \
  -e SGLANG_WATERFILL_REUSE_TOPK_BUFFER_CACHE_SIZE="${SGLANG_WATERFILL_REUSE_TOPK_BUFFER_CACHE_SIZE:-8}" \
  -e SGLANG_WATERFILL_MIN_BATCH_FOR_BALANCE="${SGLANG_WATERFILL_MIN_BATCH_FOR_BALANCE:-64}" \
  -e SGLANG_WATERFILL_FUSE_MEGA_MOE_PREDISPATCH_LOG_INTERVAL="${SGLANG_WATERFILL_FUSE_MEGA_MOE_PREDISPATCH_LOG_INTERVAL:-0}" \
  -e SGLANG_WATERFILL_RANK2_SINGLE_BLOCK_COUNT_MAX_TOKENS="${SGLANG_WATERFILL_RANK2_SINGLE_BLOCK_COUNT_MAX_TOKENS:-512}" \
  -e SGLANG_MEGA_MOE_LOG_TOPK_STATS_INTERVAL="${SGLANG_MEGA_MOE_LOG_TOPK_STATS_INTERVAL:-0}" \
  -e SGLANG_MEGA_MOE_LOG_TIMING_INTERVAL="${SGLANG_MEGA_MOE_LOG_TIMING_INTERVAL:-0}" \
  -e SGLANG_MEGA_MOE_LOG_ALL_RANKS="${SGLANG_MEGA_MOE_LOG_ALL_RANKS:-0}" \
  -e SGLANG_PROFILE_WITH_STACK="${SGLANG_PROFILE_WITH_STACK:-true}" \
  -e SGLANG_PROFILE_RECORD_SHAPES="${SGLANG_PROFILE_RECORD_SHAPES:-true}" \
  -e SGLANG_OPT_DEEPGEMM_MEGA_MOE_SYMM_MEM_BACKEND="${SGLANG_OPT_DEEPGEMM_MEGA_MOE_SYMM_MEM_BACKEND:-}" \
  -e SGLANG_OPT_DEEPGEMM_MEGA_MOE_PREINIT_ALL_CAP_BUCKETS="${SGLANG_OPT_DEEPGEMM_MEGA_MOE_PREINIT_ALL_CAP_BUCKETS:-0}" \
  -e SGLANG_OPT_DEEPGEMM_MEGA_MOE_CAP_BUCKET_MIN_FREE_GB="${SGLANG_OPT_DEEPGEMM_MEGA_MOE_CAP_BUCKET_MIN_FREE_GB:-4.0}" \
  -e SGLANG_OPT_DEEPGEMM_MEGA_MOE_USE_FP4_ACTS="${SGLANG_OPT_DEEPGEMM_MEGA_MOE_USE_FP4_ACTS:-0}" \
  -e SGLANG_OPT_DEEPGEMM_MEGA_MOE_USE_MXF4_KIND="${SGLANG_OPT_DEEPGEMM_MEGA_MOE_USE_MXF4_KIND:-0}" \
  -e SGLANG_MEGA_MOE_PREINIT_SYMM_BUFFERS="${SGLANG_MEGA_MOE_PREINIT_SYMM_BUFFERS:-1}" \
  -e SGLANG_MEGA_MOE_FORCE_WORLD_SYMM_GROUP="${SGLANG_MEGA_MOE_FORCE_WORLD_SYMM_GROUP:-0}" \
  -e SGLANG_OPT_FIX_MEGA_MOE_MEMORY="${SGLANG_OPT_FIX_MEGA_MOE_MEMORY:-1}" \
  -e NCCL_CUMEM_ENABLE="${NCCL_CUMEM_ENABLE:-1}" \
  -e NCCL_NVLS_ENABLE="${NCCL_NVLS_ENABLE:-0}" \
  -e SGLANG_DSV4_ALLOW_BF16_KV_FOR_EVAL="${SGLANG_DSV4_ALLOW_BF16_KV_FOR_EVAL:-0}" \
  -e SGLANG_DSV4_DISABLE_ASYNC_WEIGHT_LOAD="${SGLANG_DSV4_DISABLE_ASYNC_WEIGHT_LOAD:-0}" \
  -e SGLANG_WARMUP_TIMEOUT="${SGLANG_WARMUP_TIMEOUT:-0}" \
  -e DISABLE_CUDA_GRAPH="${DISABLE_CUDA_GRAPH:-1}" \
  -e DISABLE_RADIX_CACHE="${DISABLE_RADIX_CACHE:-1}" \
  -e DISABLE_SHARED_EXPERTS_FUSION="${DISABLE_SHARED_EXPERTS_FUSION:-0}" \
  -e SKIP_SERVER_WARMUP="${SKIP_SERVER_WARMUP:-1}" \
  -e TP_SIZE="${TP_SIZE:-2}" \
  -e DP_SIZE="${DP_SIZE:-1}" \
  -e MOE_DENSE_TP_SIZE="${MOE_DENSE_TP_SIZE:-1}" \
  -e ENABLE_DP_ATTENTION="${ENABLE_DP_ATTENTION:-0}" \
  -e ALLOW_READY_LOG_HEALTH="${ALLOW_READY_LOG_HEALTH:-0}" \
  -e WAIT_HEALTH_MODE="${WAIT_HEALTH_MODE:-health}" \
  -e READY_LOG_STABILIZE_SECONDS="${READY_LOG_STABILIZE_SECONDS:-60}" \
  -e MMLU_NSUB="${MMLU_NSUB:-60}" \
  -e MMLU_NUM_EXAMPLES="${MMLU_NUM_EXAMPLES:-}" \
  -e MMLU_NTRAIN="${MMLU_NTRAIN:-5}" \
  -e MMLU_SIMPLE_EXAMPLES="${MMLU_SIMPLE_EXAMPLES:-}" \
  -e GSM8K_EXAMPLES="${GSM8K_EXAMPLES:-500}" \
  -e GPQA_EXAMPLES="${GPQA_EXAMPLES:-198}" \
  -e EVAL_THREADS="${EVAL_THREADS:-128}" \
  -e EVAL_BATCH_SIZE="${EVAL_BATCH_SIZE:-128}" \
  -e DSV4_THINKING_MODE="${DSV4_THINKING_MODE:-chat}" \
  -e GPQA_THINKING_MODE="${GPQA_THINKING_MODE:-chat}" \
  -e GEN_PROMPT_MODE="${GEN_PROMPT_MODE:-dsv4-chat}" \
  -e MMLU_PROMPT_MODE="${MMLU_PROMPT_MODE:-raw}" \
  -e MMLU_SCORING="${MMLU_SCORING:-regex}" \
  -e MMLU_MAX_NEW_TOKENS="${MMLU_MAX_NEW_TOKENS:-}" \
  -e MMLU_CHOICE_PREFIX="${MMLU_CHOICE_PREFIX:-auto}" \
  -e RUN_EVAL_API="${RUN_EVAL_API:-chat}" \
  -e RUN_SMOKE="${RUN_SMOKE:-1}" \
  -e RUN_MMLU="${RUN_MMLU:-1}" \
  -e RUN_GSM8K="${RUN_GSM8K:-1}" \
  -e RUN_GPQA="${RUN_GPQA:-1}" \
  -e RUN_PREFILL_BENCH="${RUN_PREFILL_BENCH:-1}" \
  -e RUN_PREFILL_PREWARM="${RUN_PREFILL_PREWARM:-0}" \
  -e RUN_NO_WATERFILL="${RUN_NO_WATERFILL:-1}" \
  -e RUN_WATERFILL="${RUN_WATERFILL:-1}" \
  -e CASE_ORDER="${CASE_ORDER:-no_waterfill,waterfill}" \
  -e PERF_NUM_PROMPTS="${PERF_NUM_PROMPTS:-128}" \
  -e PERF_INPUT_LEN="${PERF_INPUT_LEN:-8192}" \
  -e PERF_OUTPUT_LEN="${PERF_OUTPUT_LEN:-1}" \
  -e PERF_CONCURRENCY="${PERF_CONCURRENCY:-16}" \
  -e PERF_PREWARM_PROMPTS="${PERF_PREWARM_PROMPTS:-16}" \
  -e PERF_PREWARM_CONCURRENCY="${PERF_PREWARM_CONCURRENCY:-${PERF_CONCURRENCY:-16}}" \
  -e PERF_RANDOM_RANGE_RATIO="${PERF_RANDOM_RANGE_RATIO:-0}" \
  -e PERF_DISABLE_STREAM="${PERF_DISABLE_STREAM:-0}" \
  -e PERF_WARMUP_REQUESTS="${PERF_WARMUP_REQUESTS:-8}" \
  -e PERF_MEASURE_REPEATS="${PERF_MEASURE_REPEATS:-1}" \
  -e PERF_BENCH_TIMEOUT_SEC="${PERF_BENCH_TIMEOUT_SEC:-900}" \
  -e PERF_DATASET_NAME="${PERF_DATASET_NAME:-random}" \
  -e PERF_DATASET_PATH="${PERF_DATASET_PATH:-}" \
  -e PERF_SHAREGPT_OUTPUT_LEN="${PERF_SHAREGPT_OUTPUT_LEN:-4}" \
  -e PERF_MMLU_DATA_DIR="${PERF_MMLU_DATA_DIR:-/host_scratch/mmlu_data}" \
  -e PERF_MMLU_NUM_EXAMPLES="${PERF_MMLU_NUM_EXAMPLES:-}" \
  -e PERF_MMLU_NSUB="${PERF_MMLU_NSUB:-}" \
  -e PERF_MMLU_NTRAIN="${PERF_MMLU_NTRAIN:-}" \
  -e PERF_MMLU_PROMPT_MODE="${PERF_MMLU_PROMPT_MODE:-raw}" \
  -e PERF_ENABLE_PROFILE="${PERF_ENABLE_PROFILE:-0}" \
  -e PERF_PROFILE_ACTIVITIES="${PERF_PROFILE_ACTIVITIES:-GPU}" \
  -e PERF_PROFILE_START_STEP="${PERF_PROFILE_START_STEP:-1}" \
  -e PERF_PROFILE_STEPS="${PERF_PROFILE_STEPS:-0}" \
  -e MAX_RUNNING_REQUESTS="${MAX_RUNNING_REQUESTS:-64}" \
  -v "$REPO":/workspace/sglang \
  -v "$SCRATCH":/host_scratch \
  -w /workspace/sglang \
  lmsysorg/sglang:dev \
  bash /workspace/sglang/scripts/b200_megamoe_cap_eval_inner.sh
