# Copy this file to env.local and set ENV_FILE=./env.local when running scripts.

# Local checkout mounted into the official SGLang Docker image.
SGLANG_REPO=/home/tiancij/sglang
IMAGE=lmsysorg/sglang:latest

# Model path visible on every worker node. If this is a local directory, the
# runner mounts it read-only into the same container path.
MODEL_PATH=/models/your-model
MODEL_ID=your-model
TOKENIZER_PATH=/models/your-model

# Each physical node has 8 GPUs. Keep the whole node in one PD role.
# Defaults use tensor parallelism across all 8 GPUs on the node.
# If you prefer data parallel workers, keep TP_SIZE * DP_SIZE == 8.
TP_SIZE=8
DP_SIZE=1
PORT=30000
BOOTSTRAP_PORT=8998
MEM_FRACTION_STATIC=0.9

# Transfer backend settings.
TRANSFER_BACKEND=mooncake
IB_DEVICE=mlx5_0

# SSH host aliases for the four-node experiment.
NODE0_HOST=cloud-099
NODE1_HOST=cloud-100
NODE2_HOST=cloud-101
NODE3_HOST=cloud-102
NODE0_ROLE=prefill
NODE1_ROLE=prefill
NODE2_ROLE=decode
NODE3_ROLE=decode

# Router and node URLs. Static sgl-router discovery uses each URL as worker_id.
ROUTER_HOST=127.0.0.1
ROUTER_PORT=8000
NODE0=http://10.0.0.10:30000
NODE1=http://10.0.0.11:30000
NODE2=http://10.0.0.12:30000
NODE3=http://10.0.0.13:30000

# Monitor-driven PD flip policy. Attainment is "good / total" in the monitor
# window; D->P starts when prefill TTFT attainment drops below enter threshold.
TTFT_SLO_SECONDS=0.2
TPOT_SLO_SECONDS=0.02
PD_FLIP_WINDOW_SECONDS=30
PD_FLIP_ENTER_THRESHOLD=0.9
PD_FLIP_EXIT_THRESHOLD=0.95
PD_FLIP_COMMIT_THRESHOLD=0.9
PD_FLIP_MONITOR_ITERATIONS=1
PD_FLIP_MONITOR_POLL_INTERVAL=1

# Optional extra launch args, for example:
# EXTRA_SGLANG_ARGS="--trust-remote-code"
# EXTRA_DOCKER_ARGS="-e NCCL_SOCKET_IFNAME=eth0"
# EXTRA_ROUTER_ARGS=""
EXTRA_SGLANG_ARGS=
EXTRA_DOCKER_ARGS=
EXTRA_ROUTER_ARGS=
